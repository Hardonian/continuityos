# Generate keys with: continuityos generate-evidence-keys ./secrets
CONTINUITYOS_API_KEY=replace-with-at-least-32-random-characters
CONTINUITYOS_OPERATOR_WEBHOOK_SECRET=replace-with-at-least-32-random-characters
CONTINUITYOS_OUTBOUND_HTTP_ENABLED=false
CONTINUITYOS_OUTBOUND_TIMEOUT_SECONDS=20
CONTINUITYOS_MAX_SNAPSHOT_AGE_HOURS=72
CONTINUITYOS_COMPILER_MAX_ACTIONS=24
CONTINUITYOS_MAX_REQUEST_BYTES=1048576
CONTINUITYOS_RATE_LIMIT_PER_MINUTE=60
